<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0 fw-bold">Dashboard <span class="badge bg-potiguar fw-normal">Gestor</span></h1>
    <div class="d-flex gap-1 gap-md-2">
        <% if (lookerStudioUrl) { %>
        <a href="<%= lookerStudioUrl %>" target="_blank" class="btn btn-outline-primary shadow-sm d-none d-md-inline-block fw-bold">
            <i class="bi bi-bar-chart-line me-1"></i> Looker Studio
        </a>
        <a href="<%= lookerStudioUrl %>" target="_blank" class="btn btn-outline-primary shadow-sm d-md-none" title="Looker Studio">
            <i class="bi bi-bar-chart-line"></i>
        </a>
        <% } %>
        <% if (googleSheetsUrl) { %>
        <a href="<%= googleSheetsUrl %>" target="_blank" class="btn btn-outline-success shadow-sm d-none d-md-inline-block fw-bold">
            <i class="bi bi-file-earmark-spreadsheet me-1"></i> Planilha Base
        </a>
        <a href="<%= googleSheetsUrl %>" target="_blank" class="btn btn-outline-success shadow-sm d-md-none" title="Planilha Base">
            <i class="bi bi-file-earmark-spreadsheet"></i>
        </a>
        <% } %>
        <a href="/tarefas/nova" class="btn btn-potiguar shadow-sm fw-bold">
            <i class="bi bi-plus-lg me-1"></i> <span class="d-none d-md-inline">Nova Tarefa</span><span class="d-md-none">Nova</span>
        </a>
    </div>
</div>

<!-- Linha 1: Status de Atividades -->
<div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-2 mb-3">
  <div class="col">
    <div class="card stat-card total shadow-sm h-100">
      <div class="card-body p-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1" style="font-size: 0.85rem;">Total</div>
            <div class="stat-value text-potiguar fw-bold" style="font-size: 2rem;"><%= stats.total %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-list-task fs-2 text-potiguar opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card pendente shadow-sm h-100">
      <div class="card-body p-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1" style="font-size: 0.85rem;">Pendentes</div>
            <div class="stat-value text-warning fw-bold" style="font-size: 2rem;"><%= stats.pendente %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-clock fs-2 text-warning opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card andamento shadow-sm h-100">
      <div class="card-body p-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1" style="font-size: 0.85rem;">Em Andamento</div>
            <div class="stat-value text-primary fw-bold" style="font-size: 2rem;"><%= stats.em_andamento %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-play-circle fs-2 text-primary opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card concluida shadow-sm h-100">
      <div class="card-body p-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1" style="font-size: 0.85rem;">Concluídas</div>
            <div class="stat-value text-success fw-bold" style="font-size: 2rem;"><%= stats.concluida %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-check-circle fs-2 text-success opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card atrasada shadow-sm h-100">
      <div class="card-body p-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1" style="font-size: 0.85rem;">Atrasadas</div>
            <div class="stat-value text-danger fw-bold" style="font-size: 2rem;"><%= stats.atrasada %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-exclamation-triangle fs-2 text-danger opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Linha 2: Métricas de Performance e Auditoria -->
<% const produtividadeWidth = stats.esforco_total > 0 ? Math.round((stats.esforco_concluido / stats.esforco_total) * 100) : 0; %>
<% const aderenciaTotal = (stats.aderencia_gestor_sim || 0) + (stats.aderencia_gestor_nao || 0); %>
<% const aderenciaWidth = aderenciaTotal > 0 ? Math.round(((stats.aderencia_gestor_sim || 0) / aderenciaTotal) * 100) : 0; %>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-2 mb-3">
    <div class="col">
        <div class="card stat-card shadow-sm h-100" style="border-left: 5px solid #6f42c1;">
          <div class="card-body p-3">
            <div class="row align-items-center g-0">
              <div class="col me-2">
                <div class="text-xs font-weight-bold text-muted text-uppercase mb-1" style="font-size: 0.85rem;">Produtividade</div>
                <div class="stat-value text-dark fw-bold" style="color: #6f42c1 !important; font-size: 1.8rem;">
                    <%= produtividadeWidth %>%
                </div>
                <div class="progress mt-1" style="height: 6px;">
                    <div class="progress-bar" role="progressbar" style="width: <%- produtividadeWidth %>% !important; background-color: #6f42c1;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card shadow-sm h-100" style="border-left: 5px solid #fd7e14;">
          <div class="card-body p-3">
            <div class="row align-items-center g-0">
              <div class="col me-2">
                <div class="text-xs font-weight-bold text-muted text-uppercase mb-1" style="font-size: 0.85rem;">Aderência ao Cargo</div>
                <div class="stat-value text-dark fw-bold" style="color: #fd7e14 !important; font-size: 1.8rem;">
                    <%= aderenciaWidth %>%
                </div>
                <div class="progress mt-1" style="height: 6px;">
                    <div class="progress-bar" role="progressbar" style="width: <%- aderenciaWidth %>% !important; background-color: #fd7e14;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card shadow-sm h-100" style="border-left: 5px solid #20c997;">
          <div class="card-body p-3">
            <div class="row align-items-center g-0">
              <div class="col me-2">
                <div class="text-xs font-weight-bold text-muted text-uppercase mb-1" style="font-size: 0.85rem;">Carga Horária Est.</div>
                <div class="stat-value text-dark fw-bold" style="color: #20c997 !important; font-size: 1.8rem;">
                    <%= stats.total_horas_est %>h
                </div>
              </div>
              <div class="col-auto">
                <i class="bi bi-clock-history fs-2 text-success opacity-25"></i>
              </div>
            </div>
          </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card total shadow-sm h-100" style="border-left-color: var(--potiguar-yellow);">
          <div class="card-body p-3">
            <div class="row align-items-center g-0">
              <div class="col me-2">
                <div class="text-xs font-weight-bold text-muted text-uppercase mb-1" style="font-size: 0.85rem;">Times Ativos</div>
                <div class="stat-value text-dark fw-bold" style="font-size: 1.8rem;"><%= stats.total_times %></div>
              </div>
              <div class="col-auto">
                <i class="bi bi-diagram-3 fs-2 text-dark opacity-25"></i>
              </div>
            </div>
          </div>
        </div>
    </div>
</div>

<!-- Seções de Monitoramento Expandidas -->
<div class="row g-3 flex-grow-1">
    <!-- Coluna: Atenção Prioritária (Atrasadas) -->
    <div class="col-12 col-xl-5">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold text-danger"><i class="bi bi-fire me-2"></i>Atenção Prioritária</h6>
                <a href="/tarefas" class="btn btn-link btn-sm text-decoration-none p-0 fw-bold">Ver todas</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" style="font-size: 0.85rem;">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-3 py-2">Tarefa</th>
                                <th class="py-2">Prazo</th>
                                <th class="text-end pe-3 py-2">Ação</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% 
                                const atrasadasPrioritarias = tarefas
                                    .filter(t => t.status === 'ATRASADA')
                                    .sort((a, b) => new Date(a.dataPrazo) - new Date(b.dataPrazo))
                                    .slice(0, 4);
                            %>
                            <% if (atrasadasPrioritarias.length > 0) { %>
                                <% atrasadasPrioritarias.forEach(t => { %>
                                    <tr class="align-middle">
                                        <td class="ps-3 py-2">
                                            <div class="fw-bold text-dark text-truncate" style="max-width: 180px;"><%= t.titulo %></div>
                                        </td>
                                        <td class="py-2"><span class="text-danger fw-bold"><%= new Date(t.dataPrazo).toLocaleDateString('pt-BR') %></span></td>
                                        <td class="text-end pe-3 py-2">
                                            <a href="/tarefas/<%= t.id %>" class="btn btn-sm btn-outline-danger py-0 fw-bold">Cobrar</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="3" class="text-center py-4 text-muted fw-bold small">🎉 Nenhuma tarefa atrasada!</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Coluna: Ranking de Talentos (NOVO) -->
    <div class="col-12 col-xl-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold text-potiguar"><i class="bi bi-trophy me-2 text-warning"></i>Top Performers (Mês)</h6>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <% if (stats.ranking && stats.ranking.length > 0) { %>
                        <% stats.ranking.forEach((user, index) => { %>
                            <div class="list-group-item d-flex align-items-center py-2 px-3">
                                <div class="me-3 position-relative">
                                    <img src="<%= user.fotoUrl || 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + user.nome.replace(' ', '') %>" 
                                         class="rounded-circle border" width="35" height="35">
                                    <span class="position-absolute top-0 start-0 translate-middle badge rounded-pill <%= index === 0 ? 'bg-warning' : index === 1 ? 'bg-secondary' : index === 2 ? 'bg-bronze' : 'bg-light text-dark border' %>" 
                                          style="font-size: 0.6rem; <%= index === 2 ? 'background-color: #cd7f32 !important;' : '' %>">
                                        <%= index + 1 %>º
                                    </span>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-bold text-dark small">
                                        <%= user.nome.split(' ')[0] %>
                                        <% if (user.pontos >= 50) { %>
                                            <i class="bi bi-patch-check-fill ms-1" style="color: #ffd700;" title="Medalha de Ouro (50+ pts)"></i>
                                        <% } else if (user.pontos >= 30) { %>
                                            <i class="bi bi-patch-check-fill ms-1" style="color: #c0c0c0;" title="Medalha de Prata (30+ pts)"></i>
                                        <% } else if (user.pontos >= 10) { %>
                                            <i class="bi bi-patch-check-fill ms-1" style="color: #cd7f32;" title="Medalha de Bronze (10+ pts)"></i>
                                        <% } %>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.7rem;">Pontos de Impacto</div>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-light text-potiguar border fw-bold" style="font-size: 0.85rem;"><%= user.pontos %></span>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-4 text-muted small">Aguardando conclusões do mês...</div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Coluna: Distribuição por Status (Gráfico) -->
    <div class="col-12 col-xl-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold text-potiguar"><i class="bi bi-pie-chart me-2"></i>Status</h6>
            </div>
            <div class="card-body d-flex flex-column align-items-center justify-content-evenly py-3">
                <div style="position: relative; height: 160px; width: 160px;">
                    <canvas id="statusChart"></canvas>
                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center;">
                        <div class="fw-bold" style="font-size: 1.8rem; line-height: 1;"><%= stats.total %></div>
                        <div class="text-muted fw-bold" style="font-size: 0.7rem;">TOTAL</div>
                    </div>
                </div>
                
                <div class="w-100 px-1">
                    <div class="row g-2 text-center" style="font-size: 0.72rem;">
                        <div class="col-6">
                            <div class="p-1 border rounded bg-white d-flex align-items-center justify-content-start ps-2 gap-1 shadow-sm">
                                <span style="background-color: #ffc107; width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
                                <span class="fw-bold text-dark">Pendente: <%= stats.pendente %></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-1 border rounded bg-white d-flex align-items-center justify-content-start ps-2 gap-1 shadow-sm">
                                <span style="background-color: #0d6efd; width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
                                <span class="fw-bold text-dark">Andamento: <%= stats.em_andamento %></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-1 border rounded bg-white d-flex align-items-center justify-content-start ps-2 gap-1 shadow-sm">
                                <span style="background-color: #198754; width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
                                <span class="fw-bold text-dark">Concluída: <%= stats.concluida %></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-1 border rounded bg-white d-flex align-items-center justify-content-start ps-2 gap-1 shadow-sm">
                                <span style="background-color: #dc3545; width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
                                <span class="fw-bold text-dark">Atrasada: <%= stats.atrasada %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Gráfico de Status (Rosca)
        const ctxStatus = document.getElementById('statusChart').getContext('2d');
        new Chart(ctxStatus, {
            type: 'doughnut',
            data: {
                labels: ['Pendente', 'Em Andamento', 'Concluída', 'Atrasada'],
                datasets: [{
                    data: [<%= stats.pendente %>, <%= stats.em_andamento %>, <%= stats.concluida %>, <%= stats.atrasada %>],
                    backgroundColor: ['#ffc107', '#0d6efd', '#198754', '#dc3545'],
                    borderWidth: 0,
                    cutout: '75%'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { enabled: true }
                }
            }
        });
    });
</script>

<%- include('../partials/footer') %>
