<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0 fw-bold">Dashboard <span class="badge bg-potiguar fw-normal">Gestor</span></h1>
    <div class="d-flex gap-1 gap-md-2">
        <% if (lookerStudioUrl) { %>
        <a href="<%= lookerStudioUrl %>" target="_blank" class="btn btn-outline-primary btn-sm shadow-sm d-none d-md-inline-block">
            <i class="bi bi-bar-chart-line me-1"></i> Looker Studio
        </a>
        <a href="<%= lookerStudioUrl %>" target="_blank" class="btn btn-outline-primary btn-sm shadow-sm d-md-none" title="Looker Studio">
            <i class="bi bi-bar-chart-line"></i>
        </a>
        <% } %>
        <% if (googleSheetsUrl) { %>
        <a href="<%= googleSheetsUrl %>" target="_blank" class="btn btn-outline-success btn-sm shadow-sm d-none d-md-inline-block">
            <i class="bi bi-file-earmark-spreadsheet me-1"></i> Planilha Base
        </a>
        <a href="<%= googleSheetsUrl %>" target="_blank" class="btn btn-outline-success btn-sm shadow-sm d-md-none" title="Planilha Base">
            <i class="bi bi-file-earmark-spreadsheet"></i>
        </a>
        <% } %>
        <a href="/tarefas/nova" class="btn btn-potiguar btn-sm shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> <span class="d-none d-md-inline">Nova Tarefa</span><span class="d-md-none">Nova</span>
        </a>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-3 mb-3">
  <div class="col">
    <div class="card stat-card total shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Total</div>
            <div class="stat-value text-potiguar"><%= stats.total %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-list-task fs-2 text-potiguar opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card pendente shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Pendentes</div>
            <div class="stat-value text-warning"><%= stats.pendente %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-clock fs-2 text-warning opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card andamento shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Em Andamento</div>
            <div class="stat-value text-primary"><%= stats.em_andamento %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-play-circle fs-2 text-primary opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card concluida shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Concluídas</div>
            <div class="stat-value text-success"><%= stats.concluida %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-check-circle fs-2 text-success opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card atrasada shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Atrasadas</div>
            <div class="stat-value text-danger"><%= stats.atrasada %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-exclamation-triangle fs-2 text-danger opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<% const produtividadeWidth = stats.esforco_total > 0 ? Math.round((stats.esforco_concluido / stats.esforco_total) * 100) : 0; %>
<% const aderenciaTotal = (stats.aderencia_gestor_sim || 0) + (stats.aderencia_gestor_nao || 0); %>
<% const aderenciaWidth = aderenciaTotal > 0 ? Math.round(((stats.aderencia_gestor_sim || 0) / aderenciaTotal) * 100) : 0; %>

<div class="collapse mb-2" id="collapseAudit">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3">
        <div class="col">
            <div class="card stat-card shadow-sm h-100 py-2" style="border-left: 5px solid #6f42c1;">
              <div class="card-body py-2 px-3">
                <div class="row align-items-center g-0">
                  <div class="col me-2">
                    <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Produtividade</div>
                    <div class="stat-value text-dark" style="color: #6f42c1 !important;">
                        <%= stats.esforco_total > 0 ? Math.round((stats.esforco_concluido / stats.esforco_total) * 100) : 0 %>%
                    </div>
                    <div class="progress mt-1" style="height: 4px;">
                        <div class="progress-bar" role="progressbar" style="width: <%- produtividadeWidth %>%; background-color: #6f42c1;"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
        </div>
        <div class="col">
            <div class="card stat-card shadow-sm h-100 py-2" style="border-left: 5px solid #fd7e14;">
              <div class="card-body py-2 px-3">
                <div class="row align-items-center g-0">
                  <div class="col me-2">
                    <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Aderência ao Cargo</div>
                    <div class="stat-value text-dark" style="color: #fd7e14 !important;">
                        <%= aderenciaWidth %>%                    </div>
                    <div class="progress mt-1" style="height: 4px;">
                        <div class="progress-bar" role="progressbar" style="width: <%- aderenciaWidth %>%; background-color: #fd7e14;"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
        </div>
        <div class="col">
            <div class="card stat-card shadow-sm h-100 py-2" style="border-left: 5px solid #20c997;">
              <div class="card-body py-2 px-3">
                <div class="row align-items-center g-0">
                  <div class="col me-2">
                    <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Carga Horária Est.</div>
                    <div class="stat-value text-dark" style="color: #20c997 !important;">
                        <%= stats.total_horas_est %>h
                    </div>
                    <div class="text-muted small" style="font-size: 0.7rem;">
                        <%= stats.total_horas_est > 400 ? '+' + (stats.total_horas_est - 400) + 'h extras (base 400h)' : 'Dentro da capacidade' %>
                    </div>
                  </div>
                  <div class="col-auto">
                    <i class="bi bi-clock-history fs-3 text-success opacity-25"></i>
                  </div>
                </div>
              </div>
            </div>
        </div>
        <div class="col">
            <div class="card stat-card total shadow-sm h-100 py-2" style="border-left-color: var(--potiguar-yellow);">
              <div class="card-body py-2 px-3">
                <div class="row align-items-center g-0">
                  <div class="col me-2">
                    <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Times</div>
                    <div class="stat-value text-dark"><%= stats.total_times %></div>
                  </div>
                  <div class="col-auto">
                    <i class="bi bi-diagram-3 fs-2 text-dark opacity-25"></i>
                  </div>
                </div>
              </div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-center mb-4">
    <button class="btn btn-link text-muted p-0" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAudit" aria-expanded="false" id="toggleAuditBtn" style="text-decoration: none; outline: none; box-shadow: none;">
        <i class="bi bi-chevron-down fs-4 transition-transform" id="auditChevron"></i>
    </button>
</div>

<style>
    #auditChevron {
        transition: transform 0.3s ease;
    }
    #auditChevron.rotate-180 {
        transform: rotate(180deg) !important;
    }
</style>

<script>
    const collapseAudit = document.getElementById('collapseAudit');
    const auditChevron = document.getElementById('auditChevron');
    
    // Carregar estado salvo
    const auditExpanded = localStorage.getItem('auditExpanded') === 'true';
    if (auditExpanded) {
        collapseAudit.classList.add('show');
        auditChevron.classList.add('rotate-180');
        document.getElementById('toggleAuditBtn').setAttribute('aria-expanded', 'true');
    }

    collapseAudit.addEventListener('show.bs.collapse', function () {
        auditChevron.classList.add('rotate-180');
        localStorage.setItem('auditExpanded', 'true');
    });

    collapseAudit.addEventListener('hide.bs.collapse', function () {
        auditChevron.classList.remove('rotate-180');
        localStorage.setItem('auditExpanded', 'false');
    });
</script>

<%- include('../partials/footer') %>
