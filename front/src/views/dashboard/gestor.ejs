<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0 fw-bold">Dashboard <span class="badge bg-potiguar fw-normal">Gestor</span></h1>
    <div class="d-flex gap-1 gap-md-2">
        <% if (lookerStudioUrl) { %>
        <a href="<%= lookerStudioUrl %>" target="_blank" class="btn btn-outline-primary btn-sm shadow-sm d-none d-md-inline-block">
            <i class="bi bi-bar-chart-line me-1"></i> Looker Studio
        </a>
        <a href="<%= lookerStudioUrl %>" target="_blank" class="btn btn-outline-primary btn-sm shadow-sm d-md-none" title="Looker Studio">
            <i class="bi bi-bar-chart-line"></i>
        </a>
        <% } %>
        <% if (googleSheetsUrl) { %>
        <a href="<%= googleSheetsUrl %>" target="_blank" class="btn btn-outline-success btn-sm shadow-sm d-none d-md-inline-block">
            <i class="bi bi-file-earmark-spreadsheet me-1"></i> Planilha Base
        </a>
        <a href="<%= googleSheetsUrl %>" target="_blank" class="btn btn-outline-success btn-sm shadow-sm d-md-none" title="Planilha Base">
            <i class="bi bi-file-earmark-spreadsheet"></i>
        </a>
        <% } %>
        <a href="/tarefas/nova" class="btn btn-potiguar btn-sm shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> <span class="d-none d-md-inline">Nova Tarefa</span><span class="d-md-none">Nova</span>
        </a>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-6 g-3 mb-4">
  <div class="col">
    <div class="card stat-card total shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Total</div>
            <div class="stat-value text-potiguar"><%= stats.total %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-list-task fs-2 text-potiguar opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card pendente shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Pendentes</div>
            <div class="stat-value text-warning"><%= stats.pendente %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-clock fs-2 text-warning opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card andamento shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Em Andamento</div>
            <div class="stat-value text-primary"><%= stats.em_andamento %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-play-circle fs-2 text-primary opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card concluida shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Concluídas</div>
            <div class="stat-value text-success"><%= stats.concluida %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-check-circle fs-2 text-success opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card atrasada shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Atrasadas</div>
            <div class="stat-value text-danger"><%= stats.atrasada %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-exclamation-triangle fs-2 text-danger opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card total shadow-sm h-100 py-2" style="border-left-color: var(--potiguar-yellow);">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Times</div>
            <div class="stat-value text-dark"><%= stats.total_times %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-diagram-3 fs-2 text-dark opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filtros -->
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body p-3">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label small fw-bold text-muted mb-1">BUSCAR TÍTULO</label>
                <input type="text" id="filterSearch" class="form-control form-control-sm" placeholder="Digite para buscar...">
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label small fw-bold text-muted mb-1">STATUS</label>
                <select id="filterStatus" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    <option value="PENDENTE">Pendente</option>
                    <option value="EM_ANDAMENTO">Em Andamento</option>
                    <option value="CONCLUIDA">Concluída</option>
                    <option value="ATRASADA">Atrasada</option>
                </select>
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label small fw-bold text-muted mb-1">COMPLEXIDADE</label>
                <select id="filterComplexidade" class="form-select form-select-sm">
                    <option value="">Todas</option>
                    <option value="BAIXA">Baixa</option>
                    <option value="MEDIA">Média</option>
                    <option value="ALTA">Alta</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label small fw-bold text-muted mb-1">TIME</label>
                <select id="filterTime" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    <% times.forEach(t => { %>
                        <option value="<%= t.id %>"><%= t.nome %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-12 col-md-2">
                <button id="btnClearFilters" class="btn btn-secondary btn-sm w-100">Limpar Filtros</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
    <h6 class="m-0 font-weight-bold text-potiguar fw-bold">Todas as Tarefas</h6>
    <small id="resultsCounter" class="text-muted"></small>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0 table-compact table-potiguar" id="tasksTable">
        <thead class="bg-light">
          <tr>
            <th class="ps-3 border-0">Título</th>
            <th class="border-0">Responsável/Time</th>
            <th class="border-0 cursor-pointer" data-sort="prazo">
                Prazo <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
            </th>
            <th class="border-0 cursor-pointer" data-sort="complexidade">
                Complexidade <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
            </th>
            <th class="border-0 text-center cursor-pointer" data-sort="status">
                Status <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
            </th>
            <th class="text-end pe-3 border-0">Ações</th>
          </tr>
        </thead>
        <tbody id="tasksTableBody">
          <!-- Renderizado via JS -->
        </tbody>
      </table>
    </div>
  </div>
  <div class="card-footer bg-white border-top-0 py-3">
    <nav aria-label="Navegação de tarefas">
      <ul class="pagination pagination-sm justify-content-center mb-0" id="paginationControls">
        <!-- Controles de paginação via JS -->
      </ul>
    </nav>
  </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    .cursor-pointer:hover { background-color: #f0f0f0; }
    .sort-active { color: var(--potiguar-blue); font-weight: bold; }
    .pagination .page-link { color: var(--potiguar-blue); border: none; margin: 0 2px; border-radius: 4px; }
    .pagination .page-item.active .page-link { background-color: var(--potiguar-blue); color: white; }
    .pagination .page-item.disabled .page-link { opacity: 0.5; }
</style>

<script id="tarefas-data" type="application/json">
    <%- JSON.stringify(tarefas) %>
</script>

<script>
    const allTasks = JSON.parse(document.getElementById('tarefas-data').textContent);
    let filteredTasks = [...allTasks];
    let currentSort = { column: null, direction: 'asc' };
    let currentPage = 1;
    const itemsPerPage = 10;

    const complexityWeight = { 'BAIXA': 1, 'MEDIA': 2, 'ALTA': 3 };

    function renderTable() {
        const body = document.getElementById('tasksTableBody');
        body.innerHTML = '';

        const start = (currentPage - 1) * itemsPerPage;
        const end = start + itemsPerPage;
        const pageItems = filteredTasks.slice(start, end);

        pageItems.forEach(tarefa => {
            const tr = document.createElement('tr');
            tr.className = `align-middle ${tarefa.status === 'ATRASADA' ? 'row-atrasada' : ''}`;
            
            const respNames = (tarefa.responsaveis && tarefa.responsaveis.length > 0)
                ? tarefa.responsaveis.map(r => r.nome).join(', ')
                : null;

            const respTime = respNames
                ? `<i class="bi bi-person me-1"></i>${respNames}`
                : (tarefa.time ? `<i class="bi bi-diagram-3 me-1"></i>${tarefa.time.nome}` : '-');

            const statusBadge = tarefa.status === 'CONCLUIDA' ? 'bg-success' : 
                               tarefa.status === 'ATRASADA' ? 'bg-danger' : 
                               tarefa.status === 'EM_ANDAMENTO' ? 'bg-primary' : 'bg-warning text-dark';

            const complexBadge = tarefa.complexidade === 'ALTA' ? 'bg-danger' : 
                                tarefa.complexidade === 'MEDIA' ? 'bg-warning text-dark' : 'bg-success';

            tr.innerHTML = `
                <td class="ps-3 fw-bold">${tarefa.titulo}</td>
                <td>${respTime}</td>
                <td>${new Date(tarefa.dataPrazo).toLocaleDateString('pt-BR')}</td>
                <td><span class="badge ${complexBadge}">${tarefa.complexidade}</span></td>
                <td class="text-center"><span class="badge rounded-pill ${statusBadge}">${tarefa.status.replace('_', ' ')}</span></td>
                <td class="text-end pe-3"><a href="/tarefas/${tarefa.id}" class="btn btn-sm btn-outline-secondary py-0">Detalhes</a></td>
            `;
            body.appendChild(tr);
        });

        document.getElementById('resultsCounter').innerText = `Exibindo ${start + 1}-${Math.min(end, filteredTasks.length)} de ${filteredTasks.length} tarefas`;
        renderPagination();
    }

    function renderPagination() {
        const controls = document.getElementById('paginationControls');
        controls.innerHTML = '';
        const totalPages = Math.ceil(filteredTasks.length / itemsPerPage);

        if (totalPages <= 1) return;

        // Anterior
        controls.innerHTML += `
            <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="changePage(${currentPage - 1})"><i class="bi bi-chevron-left"></i></a>
            </li>
        `;

        for (let i = 1; i <= totalPages; i++) {
            controls.innerHTML += `
                <li class="page-item ${currentPage === i ? 'active' : ''}">
                    <a class="page-link" href="#" onclick="changePage(${i})">${i}</a>
                </li>
            `;
        }

        // Próxima
        controls.innerHTML += `
            <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="changePage(${currentPage + 1})"><i class="bi bi-chevron-right"></i></a>
            </li>
        `;
    }

    function changePage(page) {
        const totalPages = Math.ceil(filteredTasks.length / itemsPerPage);
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        renderTable();
        window.scrollTo(0, document.getElementById('tasksTable').offsetTop - 100);
    }

    function filterTasks() {
        const search = document.getElementById('filterSearch').value.toLowerCase();
        const status = document.getElementById('filterStatus').value;
        const complex = document.getElementById('filterComplexidade').value;
        const timeId = document.getElementById('filterTime').value;

        // Salvar filtros no localStorage
        localStorage.setItem('dashboardFilters', JSON.stringify({
            search: document.getElementById('filterSearch').value,
            status,
            complex,
            timeId
        }));

        filteredTasks = allTasks.filter(t => {
            const matchesSearch = t.titulo.toLowerCase().includes(search);
            const matchesStatus = status === "" || t.status === status;
            const matchesComplex = complex === "" || t.complexidade === complex;
            const matchesTime = timeId === "" || (t.time && t.time.id == timeId);
            return matchesSearch && matchesStatus && matchesComplex && matchesTime;
        });

        currentPage = 1;
        if (currentSort.column) sortTasks(currentSort.column, true);
        else renderTable();
    }

    function loadFilters() {
        const savedFilters = localStorage.getItem('dashboardFilters');
        if (savedFilters) {
            const filters = JSON.parse(savedFilters);
            document.getElementById('filterSearch').value = filters.search || '';
            document.getElementById('filterStatus').value = filters.status || '';
            document.getElementById('filterComplexidade').value = filters.complex || '';
            document.getElementById('filterTime').value = filters.timeId || '';
            
            // Aplicar os filtros carregados
            filterTasks();
        } else {
            renderTable();
        }
    }

    function sortTasks(column, keepDirection = false) {
        if (!keepDirection) {
            if (currentSort.column === column) {
                currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
            } else {
                currentSort.column = column;
                currentSort.direction = 'asc';
            }
        }

        filteredTasks.sort((a, b) => {
            let valA, valB;
            if (column === 'prazo') {
                valA = new Date(a.dataPrazo);
                valB = new Date(b.dataPrazo);
            } else if (column === 'complexidade') {
                valA = complexityWeight[a.complexidade];
                valB = complexityWeight[b.complexidade];
            } else if (column === 'status') {
                valA = a.status;
                valB = b.status;
            }

            if (valA < valB) return currentSort.direction === 'asc' ? -1 : 1;
            if (valA > valB) return currentSort.direction === 'asc' ? 1 : -1;
            return 0;
        });

        updateSortIcons();
        renderTable();
    }

    function updateSortIcons() {
        document.querySelectorAll('[data-sort]').forEach(th => {
            const icon = th.querySelector('i');
            th.classList.remove('sort-active');
            icon.className = 'bi bi-arrow-down-up small opacity-50 ms-1';
            
            if (th.dataset.sort === currentSort.column) {
                th.classList.add('sort-active');
                icon.className = currentSort.direction === 'asc' ? 'bi bi-arrow-up small ms-1' : 'bi bi-arrow-down small ms-1';
                icon.classList.remove('opacity-50');
            }
        });
    }

    // Event Listeners
    document.getElementById('filterSearch').addEventListener('input', filterTasks);
    document.getElementById('filterStatus').addEventListener('change', filterTasks);
    document.getElementById('filterComplexidade').addEventListener('change', filterTasks);
    document.getElementById('filterTime').addEventListener('change', filterTasks);
    
    document.getElementById('btnClearFilters').addEventListener('click', () => {
        document.getElementById('filterSearch').value = '';
        document.getElementById('filterStatus').value = '';
        document.getElementById('filterComplexidade').value = '';
        document.getElementById('filterTime').value = '';
        localStorage.removeItem('dashboardFilters'); // Limpar memória
        filterTasks();
    });

    document.querySelectorAll('[data-sort]').forEach(th => {
        th.addEventListener('click', () => sortTasks(th.dataset.sort));
    });

    // Initial render - Agora carregando filtros primeiro
    loadFilters();
</script>

<%- include('../partials/footer') %>
s/footer') %>
