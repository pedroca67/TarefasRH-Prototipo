<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0 fw-bold">Meu Workspace <span class="badge bg-potiguar fw-normal">Colaborador</span></h1>
    <a href="/tarefas/nova" class="btn btn-potiguar btn-sm shadow-sm"><i class="bi bi-plus-lg me-1"></i> Nova Tarefa</a>
</div>

<!-- Cards de Resumo -->
<div class="row g-2 mb-4 row-cols-1 row-cols-md-3 row-cols-lg-5">
  <div class="col">
    <div class="card stat-card total shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Minhas Atribuições</div>
            <div class="stat-value text-potiguar"><%= minhasTarefas.length %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-list-task fs-3 text-potiguar opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card pendente shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Minhas Pendências</div>
            <div class="stat-value text-warning">
                <%= minhasTarefas.filter(t => t.status !== 'CONCLUIDA').length %>
            </div>
          </div>
          <div class="col-auto">
            <i class="bi bi-clock fs-3 text-warning opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card concluida shadow-sm h-100 py-2">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Minhas Concluídas</div>
            <div class="stat-value text-success">
                <%= minhasTarefas.filter(t => t.status === 'CONCLUIDA').length %>
            </div>
          </div>
          <div class="col-auto">
            <i class="bi bi-check-circle fs-3 text-success opacity-25"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card shadow-sm h-100 py-2" style="border-left-color: #6f42c1;">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Impacto Total (Mês)</div>
            <div class="stat-value" style="color: #6f42c1;"><%= impactoMensal %></div>
          </div>
          <div class="col-auto">
            <i class="bi bi-trophy fs-3 opacity-25" style="color: #6f42c1;"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card stat-card shadow-sm h-100 py-2" style="border-left-color: #fd7e14;">
      <div class="card-body py-2 px-3">
        <div class="row align-items-center g-0">
          <div class="col me-2">
            <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 small">Aderência Pessoal</div>
            <div class="stat-value" style="color: #fd7e14;"><%= aderenciaPessoal %>%</div>
            <div class="progress mt-1" style="height: 4px;">
                <div class="progress-bar" role="progressbar" style="width: <%= aderenciaPessoal %>%; background-color: #fd7e14;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Seção de Gamificação (Medalhas) -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-award-fill fs-2 text-warning me-3"></i>
                        <div>
                            <h6 class="fw-bold mb-0">Minhas Conquistas (Mês)</h6>
                            <small class="text-muted">Alcance metas de impacto para desbloquear medalhas.</small>
                        </div>
                    </div>
                    <div class="d-flex gap-4 me-3">
                        <div class="text-center <%= impactoMensal >= 10 ? '' : 'opacity-25 grayscale' %>" title="Meta: 10 pts">
                            <i class="bi bi-patch-check-fill fs-2" style="color: #cd7f32;"></i>
                            <div class="small fw-bold">Bronze</div>
                        </div>
                        <div class="text-center <%= impactoMensal >= 30 ? '' : 'opacity-25 grayscale' %>" title="Meta: 30 pts">
                            <i class="bi bi-patch-check-fill fs-2" style="color: #c0c0c0;"></i>
                            <div class="small fw-bold">Prata</div>
                        </div>
                        <div class="text-center <%= impactoMensal >= 50 ? '' : 'opacity-25 grayscale' %>" title="Meta: 50 pts">
                            <i class="bi bi-patch-check-fill fs-2" style="color: #ffd700;"></i>
                            <div class="small fw-bold">Ouro</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Destaque: Próxima Entrega Crítica -->
<% if (entregaCritica) { %>
    <div class="card border-0 shadow-sm mb-4" style="background: linear-gradient(90deg, #fff5f5 0%, #fff 100%); border-left: 5px solid #dc3545 !important;">
        <div class="card-body p-3">
            <div class="row align-items-center">
                <div class="col-auto">
                    <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="bi bi-exclamation-triangle fs-4"></i>
                    </div>
                </div>
                <div class="col">
                    <div class="text-xs font-weight-bold text-danger text-uppercase small mb-1">Próxima Entrega Crítica</div>
                    <h5 class="mb-0 fw-bold text-dark"><%= entregaCritica.titulo %></h5>
                    <div class="mt-1">
                        <span class="badge bg-light text-dark border small me-2">
                            <i class="bi bi-calendar-event me-1"></i>Prazo: <%= new Date(entregaCritica.dataPrazo).toLocaleDateString('pt-BR') %>
                        </span>
                        <span class="badge <%= entregaCritica.complexidade === 'ALTA' ? 'bg-danger' : 'bg-warning text-dark' %> small me-2">
                            <%= entregaCritica.complexidade %>
                        </span>
                        <span class="badge rounded-pill <%= entregaCritica.status === 'ATRASADA' ? 'bg-danger' : 'bg-primary' %> small">
                            <%= entregaCritica.status.replace('_', ' ') %>
                        </span>
                    </div>
                </div>
                <div class="col-auto">
                    <a href="/tarefas/<%= entregaCritica.id %>" class="btn btn-danger btn-sm px-4 fw-bold shadow-sm">
                        Resolver Agora <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
<% } else { %>
    <div class="alert alert-success border-0 shadow-sm d-flex align-items-center mb-4">
        <i class="bi bi-check-circle-fill fs-4 me-3"></i>
        <div>
            <h6 class="mb-0 fw-bold">Parabéns! Nenhuma tarefa crítica pendente.</h6>
            <small>Sua pauta individual está em dia.</small>
        </div>
    </div>
<% } %>

<!-- Filtros Rápidos -->
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body p-3">
        <div class="row g-2 align-items-center">
            <div class="col-md-8">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="liveSearch" class="form-control border-start-0" placeholder="Filtrar tarefas por título...">
                </div>
            </div>
            <div class="col-md-4">
                <select id="liveStatus" class="form-select form-select-sm">
                    <option value="">Todos os Status</option>
                    <option value="PENDENTE">Pendente</option>
                    <option value="EM_ANDAMENTO">Em Andamento</option>
                    <option value="CONCLUIDA">Concluída</option>
                    <option value="ATRASADA">Atrasada</option>
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Abas de Tarefas -->
<div class="card shadow-sm border-0">
  <div class="card-header bg-white pb-0 pt-3">
    <ul class="nav nav-tabs border-bottom-0" id="taskTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold text-potiguar" id="mine-tab" data-bs-toggle="tab" data-bs-target="#mine" type="button" role="tab">Minhas Tarefas</button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold text-potiguar" id="team-tab" data-bs-toggle="tab" data-bs-target="#team" type="button" role="tab">Tarefas do Time</button>
      </li>
    </ul>
  </div>
  <div class="card-body p-0">
    <div class="tab-content" id="taskTabsContent">
      <!-- Aba Minhas Tarefas -->
      <div class="tab-pane fade show active" id="mine" role="tabpanel">
        <div class="table-responsive">
          <table class="table table-hover mb-0 table-compact table-potiguar" id="tableMine">
            <thead class="bg-light">
              <tr>
                <th class="ps-3 border-0 cursor-pointer" data-sort="titulo" data-table="mine">
                    Título <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
                </th>
                <th class="border-0 cursor-pointer" data-sort="prazo" data-table="mine">
                    Prazo <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
                </th>
                <th class="border-0 cursor-pointer" data-sort="complexidade" data-table="mine">
                    Complexidade <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
                </th>
                <th class="border-0 text-center cursor-pointer" data-sort="status" data-table="mine">
                    Status <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
                </th>
                <th class="text-end pe-3 border-0">Ações</th>
              </tr>
            </thead>
            <tbody id="bodyMine">
              <!-- Renderizado via JS -->
            </tbody>
          </table>
        </div>
      </div>

      <!-- Aba Tarefas do Time -->
      <div class="tab-pane fade" id="team" role="tabpanel">
        <div class="table-responsive">
          <table class="table table-hover mb-0 table-compact table-potiguar" id="tableTeam">
            <thead class="bg-light">
              <tr>
                <th class="ps-3 border-0 cursor-pointer" data-sort="titulo" data-table="team">
                    Título <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
                </th>
                <th class="border-0">Responsável</th>
                <th class="border-0 cursor-pointer" data-sort="prazo" data-table="team">
                    Prazo <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
                </th>
                <th class="border-0 cursor-pointer" data-sort="complexidade" data-table="team">
                    Complexidade <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
                </th>
                <th class="border-0 text-center cursor-pointer" data-sort="status" data-table="team">
                    Status <i class="bi bi-arrow-down-up small opacity-50 ms-1"></i>
                </th>
                <th class="text-end pe-3 border-0">Ações</th>
              </tr>
            </thead>
            <tbody id="bodyTeam">
              <!-- Renderizado via JS -->
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script id="data-mine" type="application/json">
    <%- JSON.stringify(minhasTarefas) %>
</script>
<script id="data-team" type="application/json">
    <%- JSON.stringify(tarefasTime) %>
</script>

<script>
    const allMine = JSON.parse(document.getElementById('data-mine').textContent);
    const allTeam = JSON.parse(document.getElementById('data-team').textContent);
    
    let filteredMine = [...allMine];
    let filteredTeam = [...allTeam];
    
    let sortMine = { column: null, direction: 'asc' };
    let sortTeam = { column: null, direction: 'asc' };

    const complexityWeight = { 'BAIXA': 1, 'MEDIA': 2, 'ALTA': 3 };

    function renderTables() {
        renderTable('mine', filteredMine, 'bodyMine');
        renderTable('team', filteredTeam, 'bodyTeam');
    }

    function renderTable(type, data, bodyId) {
        const body = document.getElementById(bodyId);
        body.innerHTML = '';

        if (data.length === 0) {
            const cols = type === 'mine' ? 5 : 6;
            body.innerHTML = `<tr><td colspan="${cols}" class="text-center py-4 text-muted small">Nenhuma tarefa encontrada.</td></tr>`;
            return;
        }

        data.forEach(tarefa => {
            const tr = document.createElement('tr');
            tr.className = `align-middle ${tarefa.status === 'ATRASADA' ? 'row-atrasada' : ''}`;
            
            const statusBadge = tarefa.status === 'CONCLUIDA' ? 'bg-success' : 
                               tarefa.status === 'ATRASADA' ? 'bg-danger' : 
                               tarefa.status === 'EM_ANDAMENTO' ? 'bg-primary' : 'bg-warning text-dark';

            const complexBadge = tarefa.complexidade === 'ALTA' ? 'bg-danger' : 
                                tarefa.complexidade === 'MEDIA' ? 'bg-warning text-dark' : 'bg-success';

            let respHtml = '';
            if (type === 'team') {
                const respNames = (tarefa.responsaveis && tarefa.responsaveis.length > 0)
                    ? tarefa.responsaveis.map(r => r.nome).join(', ')
                    : (tarefa.time ? tarefa.time.nome : '-');
                respHtml = `<td>${respNames}</td>`;
            }

            tr.innerHTML = `
                <td class="ps-3 fw-bold">${tarefa.titulo}</td>
                ${respHtml}
                <td>${new Date(tarefa.dataPrazo).toLocaleDateString('pt-BR')}</td>
                <td><span class="badge ${complexBadge}">${tarefa.complexidade}</span></td>
                <td class="text-center">
                    <span class="badge rounded-pill ${statusBadge}">
                        ${tarefa.status.replace('_', ' ')}
                    </span>
                </td>
                <td class="text-end pe-3">
                    <a href="/tarefas/${tarefa.id}" class="btn btn-sm btn-potiguar py-0 px-3">Atualizar</a>
                </td>
            `;
            body.appendChild(tr);
        });

        // Re-inicializar paginação (função global do footer.ejs)
        if (typeof paginarTabela === 'function') {
            paginarTabela(type === 'mine' ? 'tableMine' : 'tableTeam', 10);
        }
    }

    function applyFilters(saveState = true) {
        const search = document.getElementById('liveSearch').value.toLowerCase();
        const status = document.getElementById('liveStatus').value;
        
        if (saveState) {
            localStorage.setItem('colabDashboardFilters', JSON.stringify({ search, status }));
        }

        filteredMine = allMine.filter(t => {
            const matchesSearch = t.titulo.toLowerCase().includes(search);
            const matchesStatus = status === "" || t.status === status;
            return matchesSearch && matchesStatus;
        });

        filteredTeam = allTeam.filter(t => {
            const matchesSearch = t.titulo.toLowerCase().includes(search);
            const matchesStatus = status === "" || t.status === status;
            return matchesSearch && matchesStatus;
        });

        if (sortMine.column) performSort('mine');
        if (sortTeam.column) performSort('team');
        
        renderTables();
    }

    function loadSavedState() {
        // Restaurar Filtros
        const savedFilters = localStorage.getItem('colabDashboardFilters');
        if (savedFilters) {
            const { search, status } = JSON.parse(savedFilters);
            document.getElementById('liveSearch').value = search || '';
            document.getElementById('liveStatus').value = status || '';
        }

        // Restaurar Aba Ativa
        const savedTab = localStorage.getItem('colabDashboardActiveTab');
        if (savedTab) {
            const tabEl = document.querySelector(`#taskTabs button[data-bs-target="${savedTab}"]`);
            if (tabEl) {
                const tab = new bootstrap.Tab(tabEl);
                tab.show();
            }
        }

        applyFilters(false);

        // Restaurar Scroll
        const savedScroll = sessionStorage.getItem(`scroll_${window.location.pathname}`);
        if (savedScroll) {
            window.scrollTo(0, parseInt(savedScroll));
            sessionStorage.removeItem(`scroll_${window.location.pathname}`);
        }
    }

    // Salvar aba ativa ao trocar
    document.querySelectorAll('#taskTabs button').forEach(button => {
        button.addEventListener('shown.bs.tab', (e) => {
            localStorage.setItem('colabDashboardActiveTab', e.target.getAttribute('data-bs-target'));
        });
    });

    // Salvar scroll ao clicar em um link de detalhe
    document.addEventListener('click', (e) => {
        if (e.target.closest('a') && e.target.closest('tbody')) {
            sessionStorage.setItem(`scroll_${window.location.pathname}`, window.scrollY);
        }
    });

    document.getElementById('liveSearch').addEventListener('input', () => applyFilters(true));
    document.getElementById('liveStatus').addEventListener('change', () => applyFilters(true));

    document.querySelectorAll('[data-sort]').forEach(th => {
        th.addEventListener('click', () => handleSort(th.dataset.sort, th.dataset.table));
    });

    // Inicialização
    document.addEventListener('DOMContentLoaded', () => {
        loadSavedState();
    });
</script>

<%- include('../partials/footer') %>
