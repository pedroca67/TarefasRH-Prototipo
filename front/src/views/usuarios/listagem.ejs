<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Gestão de Usuários</h1>
    <button class="btn btn-potiguar" data-bs-toggle="modal" data-bs-target="#modalUsuario">
        <i class="bi bi-person-plus me-1"></i> Novo Usuário
    </button>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-striped table-hover mb-0 table-compact table-potiguar" id="usuariosTable">
        <thead class="bg-light text-dark">
          <tr>
            <th class="ps-3 border-0">Foto</th>
            <th class="border-0">Nome</th>
            <th class="border-0">Código</th>
            <th class="border-0">E-mail</th>
            <th class="border-0">Loja</th>
            <th class="border-0">Time</th>
            <th class="border-0">Nível</th>
            <th class="border-0">Status</th>
            <th class="text-end pe-3 border-0">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% usuarios.forEach(u => { %>
            <tr class="align-middle">
              <td class="ps-3">
                <img src="<%= u.fotoUrl || 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + u.nome.replace(' ', '') %>" 
                     class="rounded-circle border" width="36" height="36" alt="<%= u.nome %>">
              </td>
              <td class="fw-bold"><%= u.nome %></td>
              <td><span class="badge bg-light text-potiguar border"><%= u.codigoFuncionario || '-' %></span></td>
              <td><%= u.email %></td>
              <td><span class="text-muted small fw-bold"><%= u.loja || '-' %></span></td>
              <td><%= u.time ? u.time.nome : '-' %></td>
              <td><span class="badge bg-light text-dark border"><%= u.nivel %></span></td>
              <td>
                <span class="badge <%= u.ativo ? 'bg-success' : 'bg-danger' %>">
                  <%= u.ativo ? 'Ativo' : 'Inativo' %>
                </span>
              </td>
              <td class="text-end pe-3">
                <a href="/usuarios/<%= u.id %>" class="btn btn-sm btn-outline-primary py-0 me-1">
                  <i class="bi bi-eye"></i> Detalhes
                </a>
                <form action="/usuarios/<%= u.id %>/toggle" method="POST" class="d-inline" onsubmit="return confirmarAcao(event, '<%= u.ativo ? 'Desativar' : 'Ativar' %> Usuário?', 'Deseja realmente <%= u.ativo ? 'desativar' : 'ativar' %> o acesso deste colaborador?')">
                  <button class="btn btn-sm <%= u.ativo ? 'btn-outline-warning' : 'btn-outline-success' %> py-0">
                    <%= u.ativo ? 'Desativar' : 'Ativar' %>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal Novo Usuário -->
<div class="modal fade" id="modalUsuario" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-potiguar text-white">
        <h5 class="modal-title fw-bold">Cadastrar Colaborador</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <form id="formUsuario" action="/usuarios" method="POST">
          <div class="mb-3">
            <label class="form-label fw-bold">Nome Completo</label>
            <input class="form-control" type="text" name="nome" required>
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold">E-mail</label>
              <input class="form-control" type="email" name="email" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold">Código do Funcionário</label>
              <input class="form-control" type="text" name="codigoFuncionario" placeholder="Ex: 12345" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">Senha Inicial</label>
            <input class="form-control" type="password" name="senha" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">Loja Associada</label>
            <select class="form-select" name="loja" required>
              <option value="">Selecione uma loja...</option>
              <optgroup label="Grande São Luís">
                <option value="Cohama">Cohama</option>
                <option value="Forquilha">Forquilha</option>
                <option value="Olho D'Água">Olho D'Água</option>
                <option value="Centro">Centro</option>
                <option value="Cohafuma">Cohafuma</option>
                <option value="Africanos">Africanos</option>
                <option value="Maiobão">Maiobão</option>
              </optgroup>
              <optgroup label="Interior">
                <option value="Imperatriz">Imperatriz</option>
                <option value="Bacabal">Bacabal</option>
                <option value="Santa Inês">Santa Inês</option>
              </optgroup>
            </select>
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold">Nível</label>
              <select class="form-select" name="nivel">
                <option value="COLABORADOR">Colaborador</option>
                <option value="GESTOR">Gestor</option>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold">Time</label>
              <select class="form-select" name="time.id">
                <option value="">Nenhum</option>
                <% times.forEach(t => { %>
                  <option value="<%= t.id %>"><%= t.nome %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </form>
      </div>
      <div class="modal-footer bg-light">
        <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-potiguar px-4" onclick="document.getElementById('formUsuario').submit()">Salvar Usuário</button>
      </div>
    </div>
  </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        paginarTabela('usuariosTable', 10);
    });
</script>

<%- include('../partials/footer') %>
