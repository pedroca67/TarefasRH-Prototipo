<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-5">
                <div class="text-center mb-5">
                    <% if (usuario.fotoUrl) { %>
                        <img src="<%= usuario.fotoUrl %>" alt="<%= usuario.nome %>" class="rounded-circle border mb-3 shadow-sm" style="width: 100px; height: 100px; object-fit: cover;">
                    <% } else { %>
                        <div class="rounded-circle bg-potiguar text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 100px; height: 100px; font-size: 2.5rem; font-weight: bold;">
                            <%= usuario.nome.charAt(0) %>
                        </div>
                    <% } %>
                    <h2 class="fw-bold text-potiguar mb-1"><%= usuario.nome %></h2>
                    <p class="text-muted"><%= usuario.email %></p>
                    <span class="badge rounded-pill bg-potiguar px-3 py-2"><%= usuario.nivel %></span>
                </div>

                <div class="row g-4 border-top pt-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Informações Gerais</label>
                        <div class="mb-3">
                            <span class="d-block text-muted small">Time</span>
                            <span class="fw-bold"><%= usuario.time ? usuario.time.nome : 'Nenhum' %></span>
                        </div>
                        <div class="mb-3">
                            <span class="d-block text-muted small">Membro desde</span>
                            <span class="fw-bold">29/05/2026</span> <!-- Valor fixo para protótipo -->
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Resumo de Atividades</label>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="small">Tarefas Atribuídas</span>
                            <span class="badge bg-light text-dark border"><%= stats.total %></span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="small">Concluídas</span>
                            <span class="badge bg-success"><%= stats.concluida %></span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="small">Atrasadas</span>
                            <span class="badge bg-danger"><%= stats.atrasada %></span>
                        </div>
                    </div>
                </div>

                <div class="mt-5 text-center">
                    <a href="/dashboard" class="btn btn-light btn-sm text-muted">
                        <i class="bi bi-arrow-left me-1"></i> Voltar para o Início
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
