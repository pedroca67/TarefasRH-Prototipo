<!-- Barra de Topo Mobile -->
<div class="mobile-top-bar">
  <div class="d-flex align-items-center">
    <button class="btn btn-link text-white p-0 me-3" id="sidebarToggleMobile">
      <i class="bi bi-list fs-2"></i>
    </button>
    <img src="/img/logoHorizontal.png" alt="Potiguar" style="max-height: 25px; filter: brightness(0) invert(1);">
  </div>
  
  <div class="mobile-user">
    <a href="/perfil">
      <% if (usuario.fotoUrl) { %>
        <img src="<%= usuario.fotoUrl %>" alt="<%= usuario.nome %>" class="mobile-user-avatar">
      <% } else { %>
        <div class="mobile-user-avatar bg-white text-potiguar d-flex align-items-center justify-content-center fw-bold">
          <%= usuario.nome.charAt(0) %>
        </div>
      <% } %>
    </a>
  </div>
</div>

<!-- Overlay para mobile -->
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<div class="sidebar" id="mainSidebar">
  <div class="sidebar-header-toggle d-flex align-items-center justify-content-between p-3 border-bottom border-white-50" style="min-height: 80px;">
    <div class="sidebar-brand">
      <img src="/img/logoHorizontal.png" alt="Potiguar" class="brand-logo" style="max-height: 35px; max-width: 140px; object-fit: contain;">
      <img src="/img/logo.jpg" alt="Potiguar" class="brand-logo-collapsed d-none" style="max-height: 30px; max-width: 45px; object-fit: contain; border-radius: 4px;">
    </div>
    <!-- Botão de fechar (X no mobile, recolher no desktop) -->
    <button class="btn btn-link text-white p-0" id="sidebarToggle">
      <i class="bi bi-list fs-3" id="sidebarToggleIcon"></i>
    </button>
  </div>
  
  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-link-custom <%= currentPage === 'dashboard' ? 'active' : '' %>">
      <i class="bi bi-grid-1x2"></i> <span><%= usuario.nivel === 'GESTOR' ? 'Dashboard' : 'Meu Workspace' %></span>
    </a>
    <a href="/tarefas/calendario" class="nav-link-custom <%= currentPage === 'calendario' ? 'active' : '' %>">
      <i class="bi bi-calendar-event"></i> <span>Meu Calendário</span>
    </a>
    
    <% if (usuario.nivel === 'GESTOR') { %>
      <a href="/tarefas" class="nav-link-custom <%= currentPage === 'tarefas' ? 'active' : '' %> position-relative">
        <i class="bi bi-card-checklist"></i> 
        <span>Gestão de Tarefas</span>
      </a>

      <a href="/usuarios" class="nav-link-custom <%= currentPage === 'usuarios' ? 'active' : '' %>">
        <i class="bi bi-people"></i> <span>Usuários</span>
      </a>
    <% } %>

    <a href="/perfil" class="nav-link-custom <%= currentPage === 'perfil' ? 'active' : '' %>">
      <i class="bi bi-person-circle"></i> <span>Meu Perfil</span>
    </a>
  </nav>

  <div class="sidebar-footer">
    <a href="/logout" class="nav-link-custom text-danger">
      <i class="bi bi-box-arrow-left"></i> <span>Sair</span>
    </a>
  </div>
</div>

<div class="main-content" id="mainContent">
  <header class="top-header">
    <div class="me-auto"></div>
    <div class="user-info d-flex align-items-center">
      <!-- Sistema de Notificações (Sino) -->
      <div class="notification-bell-wrapper" id="notifBell">
        <i class="bi bi-bell fs-4"></i>
        <span id="notificacaoBadge" class="notification-badge d-none">0</span>
        
        <div class="notification-dropdown" id="notifDropdown">
          <div class="notification-header d-flex justify-content-between align-items-center">
            <span>Notificações</span>
            <span class="badge bg-light text-muted fw-normal" style="font-size: 0.7rem;" id="notifCountLabel">0 novas</span>
          </div>
          <div class="notification-list" id="notifList">
            <!-- Renderizado via JS -->
            <div class="notification-empty">Carregando...</div>
          </div>
        </div>
      </div>

      <a href="/perfil" class="text-decoration-none d-flex align-items-center">
        <span class="me-3 text-muted small d-none d-md-inline">Bem-vindo, <strong><%= usuario.nome %></strong></span>
        <% if (usuario.fotoUrl) { %>
          <img src="<%= usuario.fotoUrl %>" alt="<%= usuario.nome %>" class="rounded-circle border" style="width: 35px; height: 35px; object-fit: cover;">
        <% } else { %>
          <div class="rounded-circle bg-potiguar text-white d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
            <%= usuario.nome.charAt(0) %>
          </div>
        <% } %>
      </a>
    </div>
  </header>
  
  <div class="content-body d-flex flex-column" style="flex: 1 0 auto;">
    <%- include('./alerts') %>

<script>
    // Gerenciamento de Notificações
    const notifBell = document.getElementById('notifBell');
    const notifDropdown = document.getElementById('notifDropdown');
    const notifBadge = document.getElementById('notificacaoBadge');
    const notifList = document.getElementById('notifList');
    const notifCountLabel = document.getElementById('notifCountLabel');

    // Polling de Contagem
    async function atualizarBadgeNotificacoes() {
        try {
            const response = await fetch(`/api/internal/notificacoes/count`);
            const data = await response.json();
            
            if (data.count > 0) {
                notifBadge.innerText = data.count > 99 ? '99+' : data.count;
                notifBadge.classList.remove('d-none');
                notifCountLabel.innerText = `${data.count} nova${data.count > 1 ? 's' : ''}`;
            } else {
                notifBadge.classList.add('d-none');
                notifCountLabel.innerText = 'Sem novas notificações';
            }
        } catch (err) {
            console.error('Erro ao buscar contagem de notificações:', err);
        }
    }

    // Carregar Lista de Notificações
    async function carregarNotificacoes() {
        try {
            const response = await fetch(`/api/internal/notificacoes`);
            const notifications = await response.json();
            
            notifList.innerHTML = '';
            
            if (notifications.length === 0) {
                notifList.innerHTML = '<div class="notification-empty">Nenhuma notificação por aqui.</div>';
                return;
            }

            notifications.forEach(n => {
                const item = document.createElement('a');
                item.href = `/tarefas/${n.referenciaId}`;
                item.className = `notification-item ${n.lida ? '' : 'unread'}`;
                
                const data = new Date(n.dataCriacao).toLocaleString('pt-BR', { 
                    day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' 
                });

                item.innerHTML = `
                    <span class="notification-msg">${n.mensagem}</span>
                    <span class="notification-time"><i class="bi bi-clock me-1"></i>${data}</span>
                `;
                notifList.appendChild(item);
            });
        } catch (err) {
            console.error('Erro ao carregar lista de notificações:', err);
            notifList.innerHTML = '<div class="notification-empty">Erro ao carregar notificações.</div>';
        }
    }

    // Toggle Dropdown
    notifBell.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = notifDropdown.classList.toggle('show');
        if (isOpen) {
            carregarNotificacoes();
        }
    });

    // Fechar dropdown ao clicar fora
    document.addEventListener('click', () => {
        notifDropdown.classList.remove('show');
    });

    // Atualiza ao carregar e a cada 60 segundos
    atualizarBadgeNotificacoes();
    setInterval(atualizarBadgeNotificacoes, 60000);
</script>
