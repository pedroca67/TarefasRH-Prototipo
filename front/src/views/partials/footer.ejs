  </div> <!-- fecha content-body -->
  <footer class="bg-white border-top mt-auto py-4">
    <div class="container text-center text-muted">
      <small>&copy; 2026 <strong>TarefasRH Potiguar</strong> - Gestão Estratégica de RH <br><span class="text-muted" style="font-size: 0.8em;">Versão Beta / Protótipo V 0.0.1</span></small>
    </div>
  </footer>
</div> <!-- fecha main-content -->
<!-- Bootstrap 5 JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Gerenciamento de estado da Sidebar
    const sidebar = document.getElementById('mainSidebar');
    const content = document.getElementById('mainContent');
    const overlay = document.getElementById('sidebar-overlay');
    const toggleBtn = document.getElementById('sidebarToggle'); // Botão dentro da sidebar
    const toggleBtnMobile = document.getElementById('sidebarToggleMobile'); // Botão hamburguer no topo
    const toggleIcon = document.getElementById('sidebarToggleIcon');

    // Aplicar estado salvo no carregamento (apenas Desktop)
    if (window.innerWidth >= 992) {
        const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
        if (isCollapsed) {
            sidebar.classList.add('collapsed');
            content.classList.add('sidebar-collapsed');
        }
    }

    function toggleSidebar() {
        if (window.innerWidth > 768) {
            // DESKTOP: Alternar entre expandido e ícones
            const nowCollapsed = sidebar.classList.toggle('collapsed');
            content.classList.toggle('sidebar-collapsed');
            localStorage.setItem('sidebarCollapsed', nowCollapsed);
        } else {
            // MOBILE: Abrir como Overlay
            const nowOpen = sidebar.classList.toggle('open');
            overlay.classList.toggle('active', nowOpen);
            
            // Trocar ícone para X quando aberto no mobile
            if (toggleIcon) {
                if (nowOpen) {
                    toggleIcon.classList.replace('bi-list', 'bi-x-lg');
                } else {
                    toggleIcon.classList.replace('bi-x-lg', 'bi-list');
                }
            }
        }
    }

    function closeSidebarMobile() {
        if (window.innerWidth <= 768) {
            sidebar.classList.remove('open');
            overlay.classList.remove('active');
            if (toggleIcon) {
                toggleIcon.classList.replace('bi-x-lg', 'bi-list');
            }
        }
    }

    toggleBtn?.addEventListener('click', toggleSidebar);
    toggleBtnMobile?.addEventListener('click', toggleSidebar);
    overlay?.addEventListener('click', closeSidebarMobile);

    // Ajustar estado ao redimensionar a janela
    window.addEventListener('resize', () => {
        if (window.innerWidth > 768) {
            closeSidebarMobile();
        }
    });

    function confirmarAcao(event, titulo, texto) {
        event.preventDefault();
        const form = event.target.closest('form');
        
        Swal.fire({
            title: titulo || 'Tem certeza?',
            text: texto || 'Esta ação não pode ser desfeita.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ed1a25',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Sim, confirmar!',
            cancelButtonText: 'Cancelar',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
        return false;
    }

    function paginarTabela(tableId, itemsPerPage = 10) {
        const table = document.getElementById(tableId);
        if (!table) return;
        
        const tbody = table.querySelector('tbody');
        const rows = Array.from(tbody.querySelectorAll('tr:not(.no-data)'));
        const totalPages = Math.ceil(rows.length / itemsPerPage);
        
        if (totalPages <= 1) return;

        // MUDANÇA: Usar sessionStorage em vez de localStorage para que expire ao fechar o navegador/aba
        let currentPage = parseInt(sessionStorage.getItem(`pag_${tableId}`) || '1');
        if (currentPage > totalPages) currentPage = 1;

        // Criar container de paginação se não existir
        let paginationContainer = table.nextElementSibling;
        if (!paginationContainer || !paginationContainer.classList.contains('pagination-container')) {
            paginationContainer = document.createElement('div');
            paginationContainer.className = 'pagination-container d-flex justify-content-center py-3 bg-white border-top';
            table.parentNode.insertBefore(paginationContainer, table.nextSibling);
        }

        function showPage(page) {
            currentPage = page;
            sessionStorage.setItem(`pag_${tableId}`, page); 
            
            const start = (page - 1) * itemsPerPage;
            const end = start + itemsPerPage;

            rows.forEach((row, index) => {
                row.style.display = (index >= start && index < end) ? '' : 'none';
            });

            renderControls();
        }

        function renderControls() {
            paginationContainer.innerHTML = '';
            const nav = document.createElement('nav');
            const ul = document.createElement('ul');
            ul.className = 'pagination pagination-sm mb-0';

            // Anterior
            const liPrev = document.createElement('li');
            liPrev.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
            liPrev.innerHTML = `<a class="page-link" href="#" onclick="event.preventDefault()"><i class="bi bi-chevron-left"></i></a>`;
            liPrev.onclick = (e) => { e.preventDefault(); if (currentPage > 1) showPage(currentPage - 1); };
            ul.appendChild(liPrev);

            // Lógica de Janela Deslizante
            const range = 2; 
            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - range && i <= currentPage + range)) {
                    const li = document.createElement('li');
                    li.className = `page-item ${currentPage === i ? 'active' : ''}`;
                    li.innerHTML = `<a class="page-link" href="#" onclick="event.preventDefault()">${i}</a>`;
                    li.onclick = (e) => { e.preventDefault(); showPage(i); };
                    ul.appendChild(li);
                } else if (i === currentPage - range - 1 || i === currentPage + range + 1) {
                    const li = document.createElement('li');
                    li.className = 'page-item disabled';
                    li.innerHTML = '<span class="page-link">...</span>';
                    ul.appendChild(li);
                }
            }

            // Próximo
            const liNext = document.createElement('li');
            liNext.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
            liNext.innerHTML = `<a class="page-link" href="#" onclick="event.preventDefault()"><i class="bi bi-chevron-right"></i></a>`;
            liNext.onclick = (e) => { e.preventDefault(); if (currentPage < totalPages) showPage(currentPage + 1); };
            ul.appendChild(liNext);

            nav.appendChild(ul);
            paginationContainer.appendChild(nav);
        }

        showPage(currentPage);
    }

    // Lógica Global de Restauração de Scroll
    document.addEventListener('DOMContentLoaded', () => {
        const scrollKey = `scroll_${window.location.pathname}${window.location.search}`;
        
        // 1. Restaurar scroll se existir
        const savedScroll = sessionStorage.getItem(scrollKey);
        if (savedScroll) {
            // Pequeno delay para garantir que o DOM (especialmente tabelas e gráficos) esteja renderizado
            setTimeout(() => {
                window.scrollTo(0, parseInt(savedScroll));
                sessionStorage.removeItem(scrollKey);
            }, 100);
        }

        // 2. Salvar scroll ao clicar em links que navegam para fora (ex: detalhes da tarefa)
        document.addEventListener('click', (e) => {
            const link = e.target.closest('a');
            if (link && link.href && !link.href.includes('#') && link.hostname === window.location.hostname) {
                sessionStorage.setItem(scrollKey, window.scrollY);
            }
        });
    });

    // Função para limpar memórias de página ao fazer logout ou trocar de contexto maior
    function limparMemoriasDeNavegacao() {
        // Limpa tudo o que começa com pag_ ou scroll_
        Object.keys(sessionStorage).forEach(key => {
            if (key.startsWith('pag_') || key.startsWith('scroll_')) {
                sessionStorage.removeItem(key);
            }
        });
        localStorage.removeItem('colabDashboardActiveTab');
        localStorage.removeItem('colabDashboardFilters');
        localStorage.removeItem('dashboardFilters');
    }
</script>
</body>
</html>
