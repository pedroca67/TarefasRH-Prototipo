<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="row justify-content-center">
  <div class="col-12 col-lg-10">
    <div class="card shadow-sm <%= tarefa.status === 'CONCLUIDA' ? 'card-header-concluida' : tarefa.status === 'ATRASADA' ? 'card-header-atrasada' : 'card-header-total' %>">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start mb-4">
          <div>
            <h1 class="h2 fw-bold text-potiguar mb-1">
                <%= tarefa.titulo %>
                <% if (tarefa.criadoPor && tarefa.responsaveis && tarefa.responsaveis.some(r => r.id === tarefa.criadoPor.id)) { %>
                    <span class="badge bg-info text-dark ms-2 small fw-normal" style="font-size: 0.8rem;">
                        <i class="bi bi-person-check me-1"></i> Auto-atribuída
                    </span>
                <% } %>
            </h1>
            <p class="text-muted small">
              <i class="bi bi-calendar-event me-1"></i>Criada em: <%= new Date(tarefa.dataCriacao).toLocaleString('pt-BR') %>
              <% if (tarefa.criadoPor) { %>
                <span class="ms-3"><i class="bi bi-person-badge me-1"></i>Por: <strong><%= tarefa.criadoPor.nome %></strong></span>
              <% } %>
            </p>
          </div>
          <span class="badge rounded-pill px-3 py-2 <%= tarefa.status === 'CONCLUIDA' ? 'bg-success' : tarefa.status === 'ATRASADA' ? 'bg-danger' : tarefa.status === 'EM_ANDAMENTO' ? 'bg-primary' : 'bg-warning text-dark' %>">
            <%= tarefa.status.replace('_', ' ') %>
          </span>
        </div>

        <div class="row g-4">
          <div class="col-12">
            <h6 class="fw-bold border-bottom pb-2">Descrição</h6>
            <p class="text-secondary"><%= tarefa.descricao || 'Sem descrição.' %></p>
          </div>
          
          <div class="col-md-3">
            <div class="p-3 bg-light rounded h-100">
                <small class="text-muted d-block fw-bold text-uppercase">Complexidade</small>
                <span class="badge <%= tarefa.complexidade === 'ALTA' ? 'bg-danger' : 'bg-secondary' %>"><%= tarefa.complexidade %></span>
            </div>
          </div>
          <div class="col-md-3">
            <div class="p-3 bg-light rounded h-100">
                <small class="text-muted d-block fw-bold text-uppercase">Categoria</small>
                <span class="badge bg-potiguar"><%= tarefa.categoria.replace(/_/g, ' ') %></span>
            </div>
          </div>
          <div class="col-md-3">
            <div class="p-3 bg-light rounded h-100">
                <small class="text-muted d-block fw-bold text-uppercase">Expectativa Cargo</small>
                <% if (tarefa.previstoNoCargoGestor) { %>
                    <span class="text-success fw-bold small"><i class="bi bi-shield-check me-1"></i>No Cargo</span>
                <% } else { %>
                    <span class="text-danger fw-bold small"><i class="bi bi-shield-exclamation me-1"></i>Extra-Cargo</span>
                <% } %>
            </div>
          </div>
          <% if (tarefa.status === 'CONCLUIDA' && tarefa.previstoNoCargoColaborador !== null) { %>
            <div class="col-md-3">
              <div class="p-3 bg-light rounded h-100 border-start border-3 border-potiguar">
                  <small class="text-muted d-block fw-bold text-uppercase">Realidade Cargo</small>
                  <% if (tarefa.previstoNoCargoColaborador) { %>
                      <span class="text-success fw-bold small"><i class="bi bi-check-circle me-1"></i>No Cargo</span>
                  <% } else { %>
                      <span class="text-danger fw-bold small"><i class="bi bi-exclamation-circle me-1"></i>Extra-Cargo</span>
                  <% } %>
              </div>
            </div>
          <% } %>
          <div class="col-md-3">
            <div class="p-3 bg-light rounded h-100">
                <small class="text-muted d-block fw-bold text-uppercase">Prazo</small>
                <span class="fw-bold text-dark"><%= new Date(tarefa.dataPrazo).toLocaleDateString('pt-BR') %></span>
            </div>
          </div>

          <div class="col-12">
            <div class="p-3 bg-light rounded">
                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted d-block fw-bold text-uppercase">Responsável(is)</small>
                        <span class="fw-bold text-dark">
                          <% if (tarefa.time) { %>
                            <i class="bi bi-people me-1"></i>Time: <%= tarefa.time.nome %>
                          <% } else if (tarefa.responsaveis && tarefa.responsaveis.length > 0) { %>
                            <i class="bi bi-person me-1"></i><%= tarefa.responsaveis.map(r => r.nome).join(', ') %>
                          <% } else { %>
                            Nenhum
                          <% } %>
                        </span>
                    </div>
                    <div class="col-md-6 border-start">
                        <small class="text-muted d-block fw-bold text-uppercase">Criado por / Unidade</small>
                        <span class="fw-bold text-dark">
                            <i class="bi bi-person-plus me-1"></i><%= tarefa.criadoPor ? tarefa.criadoPor.nome : 'Sistema' %>
                            <span class="badge bg-secondary ms-2"><%= tarefa.criadoPor ? tarefa.criadoPor.loja : '-' %></span>
                        </span>
                    </div>
                </div>
            </div>
          </div>
        </div>

        <% if (tarefa.evidencia) { %>
          <div class="alert alert-info mt-4">
            <h6 class="alert-heading fw-bold"><i class="bi bi-info-circle me-2"></i>Evidência de Conclusão</h6>
            <p class="mb-0 small"><%= tarefa.evidencia %></p>
            <% if (tarefa.dataConclusao) { %>
                <hr>
                <p class="mb-0 small text-muted">
                    <i class="bi bi-calendar-check me-1"></i> Finalizada em: <strong><%= new Date(tarefa.dataConclusao).toLocaleString('pt-BR') %></strong>
                </p>
            <% } %>
          </div>
        <% } %>

        <% if (tarefa.feedbackGestor) { %>
          <div class="card border-warning mt-4 shadow-sm" style="background-color: #fffdf0;">
            <div class="card-body">
              <h6 class="fw-bold text-dark mb-2"><i class="bi bi-chat-left-quote me-2 text-warning"></i>Feedback do Gestor</h6>
              <p class="mb-0 text-secondary" style="font-style: italic;">"<%= tarefa.feedbackGestor %>"</p>
              <% if (tarefa.dataFeedback) { %>
                <small class="text-muted d-block mt-2" style="font-size: 0.75rem;">
                    <i class="bi bi-clock me-1"></i> Recebido em: <%= new Date(tarefa.dataFeedback).toLocaleString('pt-BR') %>
                </small>
              <% } %>
            </div>
          </div>
        <% } %>

        <% if (usuario.nivel === 'GESTOR' && tarefa.status === 'CONCLUIDA' && !tarefa.feedbackGestor) { %>
          <div class="card bg-light border-0 mt-4 shadow-sm">
            <div class="card-body">
              <h6 class="fw-bold text-potiguar mb-3"><i class="bi bi-patch-check me-2"></i>Avaliar Conclusão (Feedback)</h6>
              <form action="/tarefas/<%= tarefa.id %>/feedback" method="POST">
                <div class="mb-3">
                  <textarea class="form-control" name="feedback" rows="2" placeholder="Escreva um feedback construtivo sobre a entrega..." required></textarea>
                </div>
                <button type="submit" class="btn btn-sm btn-potiguar fw-bold px-4">Enviar Feedback</button>
              </form>
            </div>
          </div>
        <% } %>

        <% 
          const isResponsavel = (tarefa.responsaveis && tarefa.responsaveis.some(r => r.id === usuario.id)) || 
                               (tarefa.time && usuario.time && tarefa.time.id === usuario.time.id);
        %>

        <% if (isResponsavel && tarefa.status !== 'CONCLUIDA') { %>
          <hr class="my-4">
          <h5 class="fw-bold mb-3"><i class="bi bi-arrow-repeat me-2"></i>Atualizar Status</h5>
          <form action="/tarefas/<%= tarefa.id %>/status" method="POST" onsubmit="return handleStatusSubmit(event)">
            <div class="row align-items-end g-3">
              <div class="col-md-4">
                <label class="form-label fw-bold">Novo Status</label>
                <select class="form-select" name="status" id="statusSelect" onchange="toggleEvidencia(this.value)">
                  <option value="PENDENTE" <%= tarefa.status === 'PENDENTE' ? 'selected' : '' %>>Pendente</option>
                  <option value="EM_ANDAMENTO" <%= tarefa.status === 'EM_ANDAMENTO' ? 'selected' : '' %>>Em Andamento</option>
                  <option value="CONCLUIDA">Concluída</option>
                </select>
              </div>

              <div class="col-md-8" id="evidenciaField" style="display: none;">
                <div class="mb-3">
                    <label class="form-label fw-bold">Evidência (Obrigatório para concluir)</label>
                    <textarea class="form-control" name="evidencia" rows="1" placeholder="Descreva o que foi feito..."></textarea>
                </div>
                
                <div class="p-3 bg-light rounded border">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <label class="form-label fw-bold text-potiguar mb-0">Na sua visão, como executor, esta atividade faz parte do seu descritivo de cargo?</label>
                            <p class="text-muted small mb-0">Sua resposta ajuda na auditoria de processos.</p>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <span id="previstoLabelConcluir" class="fw-bold text-success" style="min-width: 35px; text-align: right;">Sim</span>
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" name="previstoNoCargoColaborador" id="previstoNoCargoConcluir" value="true" checked style="width: 3.5em; height: 1.75em; cursor: pointer;">
                            </div>
                        </div>
                    </div>
                </div>
              </div>

              <div class="col-12 mt-3">
                <button type="submit" class="btn btn-potiguar px-4" id="btnSubmitStatus">
                    Salvar Alteração
                </button>
              </div>
            </div>
          </form>
        <% } %>
        
        <div class="mt-5">
          <a href="/dashboard" class="btn btn-light text-muted btn-sm"><i class="bi bi-arrow-left me-1"></i>Voltar para Dashboard</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function toggleEvidencia(status) {
  const field = document.getElementById('evidenciaField');
  field.style.display = (status === 'CONCLUIDA') ? 'block' : 'none';
  const textarea = field.querySelector('textarea');
  if (status === 'CONCLUIDA') textarea.setAttribute('required', 'required');
  else textarea.removeAttribute('required');
}

// Lógica do toggle na conclusão
if (document.getElementById('previstoNoCargoConcluir')) {
    document.getElementById('previstoNoCargoConcluir').addEventListener('change', function() {
      const label = document.getElementById('previstoLabelConcluir');
      if (this.checked) {
        label.innerText = 'Sim';
        label.className = 'fw-bold text-success';
        this.value = "true";
      } else {
        label.innerText = 'Não';
        label.className = 'fw-bold text-danger';
        this.value = "false";
      }
    });
}

function handleStatusSubmit(e) {
    const status = document.getElementById('statusSelect').value;
    if (status === 'CONCLUIDA') {
        return confirmarAcao(e, 'Concluir Tarefa?', 'Deseja realmente marcar esta tarefa como concluída?');
    }
    return true;
}
</script>

<%- include('../partials/footer') %>
