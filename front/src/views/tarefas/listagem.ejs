<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0 fw-bold">Gestão de Tarefas</h1>
    
    <div class="d-flex align-items-center gap-2">
        <!-- Filtro de Período -->
        <form action="/tarefas" method="GET" id="periodFilterForm" class="d-flex align-items-center gap-2 bg-white p-2 rounded shadow-sm border">
            <label class="small fw-bold text-muted mb-0 d-none d-lg-inline">PERÍODO:</label>
            <select name="periodo" id="periodoSelect" class="form-select form-select-sm border-0 bg-light fw-bold" style="width: auto; min-width: 140px;">
                <option value="todos" <%= filtro.periodo === 'todos' ? 'selected' : '' %>>Todo o período</option>
                <option value="semana" <%= filtro.periodo === 'semana' ? 'selected' : '' %>>Esta semana</option>
                <option value="mes" <%= filtro.periodo === 'mes' ? 'selected' : '' %>>Este mês</option>
                <option value="ano" <%= filtro.periodo === 'ano' ? 'selected' : '' %>>Este ano</option>
                <option value="personalizado" <%= filtro.periodo === 'personalizado' ? 'selected' : '' %>>Personalizado...</option>
            </select>
            
            <div id="customDates" class="d-flex align-items-center gap-2 <%= filtro.periodo === 'personalizado' ? '' : 'd-none' %>">
                <input type="date" name="dataDe" value="<%= filtro.dataDe %>" class="form-control form-control-sm border-0 bg-light" style="width: 130px;">
                <span class="small text-muted">até</span>
                <input type="date" name="dataAte" value="<%= filtro.dataAte %>" class="form-control form-control-sm border-0 bg-light" style="width: 130px;">
                <button type="submit" class="btn btn-sm btn-potiguar py-1 px-2"><i class="bi bi-check-lg"></i></button>
            </div>
        </form>

        <a href="/tarefas/nova" class="btn btn-potiguar btn-sm shadow-sm h-100 py-2 px-3 fw-bold">
            <i class="bi bi-plus-lg me-1"></i> Nova Tarefa
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
    <h6 class="m-0 font-weight-bold text-potiguar fw-bold">Listagem de Atividades</h6>
    <small class="text-muted">Total: <%= pagination.totalItems %> tarefas</small>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0 table-compact table-potiguar" id="tasksTable">
        <thead class="bg-light">
          <tr>
            <th class="ps-3 border-0">Título</th>
            <th class="border-0">Responsável/Time</th>
            <th class="border-0">Prazo</th>
            <th class="border-0">Complexidade</th>
            <th class="border-0 text-center">Status</th>
            <th class="text-end pe-3 border-0">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% tarefas.forEach(tarefa => { %>
            <% 
               const isAtrasadaVisual = tarefa.status !== 'CONCLUIDA' && new Date(tarefa.dataPrazo) < new Date(new Date().setHours(0,0,0,0));
               const respNames = (tarefa.responsaveis && tarefa.responsaveis.length > 0) ? tarefa.responsaveis.map(r => r.nome).join(', ') : null;
               const respTime = respNames ? respNames : (tarefa.time ? tarefa.time.nome : '-');
            %>
            <tr class="align-middle <%= tarefa.status === 'ATRASADA' ? 'row-atrasada' : '' %>">
              <td class="ps-3 fw-bold">
                <%= tarefa.titulo %>
                <div class="text-muted" style="font-size: 0.7rem; font-weight: normal;">
                    <i class="bi bi-person-plus me-1"></i>Criado por: <%= tarefa.criadoPor ? tarefa.criadoPor.nome : 'Sistema' %>
                </div>
              </td>
              <td><i class="bi bi-person me-1"></i><%= respTime %></td>
              <td class="<%= isAtrasadaVisual ? 'text-danger fw-bold' : '' %>">
                <%= new Date(tarefa.dataPrazo).toLocaleDateString('pt-BR') %>
                <% if (isAtrasadaVisual) { %><i class="bi bi-exclamation-triangle-fill ms-1"></i><% } %>
              </td>
              <td>
                <span class="badge <%= tarefa.complexidade === 'ALTA' ? 'bg-danger' : tarefa.complexidade === 'MEDIA' ? 'bg-warning text-dark' : 'bg-success' %>">
                    <%= tarefa.complexidade %>
                </span>
              </td>
              <td class="text-center">
                <span class="badge rounded-pill <%= tarefa.status === 'CONCLUIDA' ? 'bg-success' : tarefa.status === 'ATRASADA' ? 'bg-danger' : tarefa.status === 'EM_ANDAMENTO' ? 'bg-primary' : 'bg-warning text-dark' %>">
                    <%= tarefa.status.replace('_', ' ') %>
                </span>
              </td>
              <td class="text-end pe-3">
                <a href="/tarefas/<%= tarefa.id %>" class="btn btn-sm btn-outline-secondary py-0">Detalhes</a>
              </td>
            </tr>
          <% }) %>
          <% if (tarefas.length === 0) { %>
            <tr><td colspan="6" class="text-center py-5 text-muted">Nenhuma tarefa encontrada no período.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  
  <% if (pagination.totalPages > 1) { %>
    <div class="card-footer bg-white border-top py-3">
        <nav aria-label="Navegação">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <!-- Anterior -->
                <li class="page-item <%= pagination.page === 0 ? 'disabled' : '' %>">
                    <a class="page-link" href="/tarefas?page=<%= pagination.page - 1 %>&periodo=<%= filtro.periodo %>&dataDe=<%= filtro.dataDe %>&dataAte=<%= filtro.dataAte %>">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                <!-- Janela de Páginas -->
                <% 
                   const range = 2;
                   for(let i = 0; i < pagination.totalPages; i++) { 
                       if (i === 0 || i === pagination.totalPages - 1 || (i >= pagination.page - range && i <= pagination.page + range)) {
                %>
                        <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
                            <a class="page-link" href="/tarefas?page=<%= i %>&periodo=<%= filtro.periodo %>&dataDe=<%= filtro.dataDe %>&dataAte=<%= filtro.dataAte %>"><%= i + 1 %></a>
                        </li>
                <% 
                       } else if (i === pagination.page - range - 1 || i === pagination.page + range + 1) { 
                %>
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                <% 
                       }
                   } 
                %>

                <!-- Próxima -->
                <li class="page-item <%= pagination.page === pagination.totalPages - 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="/tarefas?page=<%= pagination.page + 1 %>&periodo=<%= filtro.periodo %>&dataDe=<%= filtro.dataDe %>&dataAte=<%= filtro.dataAte %>">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
  <% } %>
</div>

<script>
    document.getElementById('periodoSelect')?.addEventListener('change', function() {
        if (this.value === 'personalizado') {
            document.getElementById('customDates').classList.remove('d-none');
        } else {
            document.getElementById('periodFilterForm').submit();
        }
    });
</script>

<%- include('../partials/footer') %>